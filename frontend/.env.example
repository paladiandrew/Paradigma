# Сборка фронта для продакшена: скопируйте в .env.production или задайте в командной строке.
# URL сайта БЕЗ завершающего слэша — тот же хост, что открывает пользователь в браузере
# (Nginx отдаёт SPA и проксирует /api на бэкенд).
#
# Продакшен (тот же хост, без слэша в конце):
# VITE_API_URL=https://paradigma-bjj.ru

VITE_API_URL=https://paradigma-bjj.ru
