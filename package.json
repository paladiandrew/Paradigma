{
  "name": "paradigma-bjj",
  "version": "1.0.0",
  "description": "Paradigma BJJ - Клуб бразильского джиу-джитсу",
  "private": true,
  "scripts": {
    "dev": "concurrently -n \"FRONTEND,BACKEND\" -c \"cyan,magenta\" \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "node scripts/start-backend.js",
    "dev:backend:simple": "cd backend && python -m uvicorn app.main:app --reload",
    "install:all": "npm install && cd frontend && npm install",
    "install:all:win": "scripts\\install-all.bat",
    "install:all:unix": "bash scripts/install-all.sh",
    "build": "cd frontend && npm run build"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}

